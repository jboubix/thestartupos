<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_plan_tree" model="ir.ui.view">
        <field name="name">startupos.plan.tree</field>
        <field name="model">startupos.plan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="price_monthly"/>
                <field name="max_users"/>
                <field name="ai_calls_per_month"/>
                <field name="storage_gb"/>
            </tree>
        </field>
    </record>
    <record id="view_plan_form" model="ir.ui.view">
        <field name="name">startupos.plan.form</field>
        <field name="model">startupos.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="price_monthly"/>
                        <field name="max_users"/>
                        <field name="ai_calls_per_month"/>
                        <field name="storage_gb"/>
                        <field name="module_ids" widget="many2many_tags"/>
                        <field name="description"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_plans" model="ir.actions.act_window">
        <field name="name">Plans</field>
        <field name="res_model">startupos.plan</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
